  "kind": "diagnostic_quality",
  "fixture": "broken-change-packet",
  "prompt": "Audit the hub and analyze broken-change, then recommend next actions.",
  "expected": {
    "diagnostic_fields": [
      "code",
      "severity",
      "target",
      "message",
      "recommendation"
