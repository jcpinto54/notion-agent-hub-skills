  "must_not": [
    "freeform_only_diagnostics",
    "unstable_code_names",
    "recommendation_without_target"
  ],
  "rubric": [
    {
      "id": "machine_readable",
      "requirement": "Every diagnostic includes stable machine-readable fields."
    },
    {
      "id": "actionable_recommendation",
      "requirement": "Recommendations identify the file or deterministic command needed to fix the issue."
    }
  ]
